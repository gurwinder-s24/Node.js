{
  "name": "threads-backend",
  "version": "1.0.0",
  "description": "Backend for Threads app",
  "main": "build/index.js",
  "type": "module",
  "scripts": {
    "compose-down": "docker compose down",
    "compose-up": "docker compose up -d",
    "list-containers": "docker ps",
    "container-terminal": "docker exec -it 123456789012 bash",

    "generate": "prisma generate",
    "migrate-reset": "prisma migrate reset --force",
    "migrate": "prisma migrate dev --name createDB",
    "build": "tsc",
    "start": "node build/index.js",
    "dev": "tsc-watch --onSuccess \"npm start\""

  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.2",
    "prisma": "^7.6.0",
    "tsc-watch": "^7.2.0",
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "@apollo/server": "^5.5.0",
    "@as-integrations/express5": "^1.1.2",
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "^7.6.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.0",
    "express": "^5.2.1",
    "graphql": "^16.13.2",
    "pg": "^8.20.0"
  }
}
